{
    "name": "kirstenroschanski/contao-widerruf-bundle",
    "description": "Widerrufsmodul fuer Contao",
    "type": "contao-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^4.13 || ^5.0",
        "terminal42/notification_center": "^1.6 || ^1.7 || ^2.0",
        "markocupic/contao-altcha-antispam": "^0.7"
    },
    "autoload": {
        "psr-4": {
            "Kirstenroschanski\\ContaoWiderrufBundle\\": "src/"
        }
    },
    "extra": {
            "contao-manager-plugin": "Kirstenroschanski\\ContaoWiderrufBundle\\ContaoManager\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "php-http/discovery": true
        }
    }
}
